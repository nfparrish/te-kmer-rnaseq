/*
 * te-kmer-rnaseq pipeline configuration
 */

// ── Default parameters ─────────────────────────────────────────────
params {
    reads        = null
    species      = 'human'
    k            = 50
    max_mismatch = 10
    max_clip     = 10
    n_clusters   = 50
    te_consensus = null
    outdir       = 'results'
}

// ── Process defaults ───────────────────────────────────────────────
process {
    cpus   = 4
    memory = '8 GB'
    time   = '4h'

    withName: 'BUILD_BOWTIE2_INDEX' {
        cpus   = 8
        memory = '16 GB'
    }
    withName: 'MAP_TO_TE_CONSENSUS' {
        cpus   = 8
        memory = '16 GB'
        time   = '8h'
    }
    withName: 'EXTRACT_KMERS' {
        memory = '16 GB'
        time   = '6h'
    }
    withName: 'MERGE_KMER_COUNTS' {
        memory = '32 GB'
        time   = '4h'
    }
    withName: 'CLUSTER_KMERS' {
        memory = '32 GB'
        time   = '4h'
    }
}

// ── Profiles ───────────────────────────────────────────────────────
profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }
    docker {
        docker.enabled = true
        process.container = 'quay.io/biocontainers/mulled-v2-bowtie2-samtools:latest'
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// ── Manifest ───────────────────────────────────────────────────────
manifest {
    name            = 'te-kmer-rnaseq'
    author          = 'te-kmer-rnaseq contributors'
    description     = 'TE expression quantification via k-mer decomposition of RNA-seq reads mapped to Dfam consensus sequences'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0'
}

// ── Reports ────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
}
